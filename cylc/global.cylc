# Add this to ~/.bashrc so Cylc can find this global config file.
# export CYLC_CONF_PATH=/nesi/project/nesi00213/sw4_scale_tests/scale_test/cylc
# Then run: source ~/.bashrc

[platforms]
    [[mahuika]]
        hosts = localhost
        job runner = slurm
        install target = localhost

[install]
    source dirs = /nesi/project/nesi00213/sw4_scale_tests/scale_test/cylc/cylc-src
    [[symlink dirs]]
        [[[localhost]]]
            run = /nesi/project/nesi00213/sw4_scale_tests/scale_tests/cylc